# 무임하차 — Caddy v2 리버스 프록시 + 정적 SPA 서빙
#
# {$DOMAIN} 환경변수(루트 .env의 DOMAIN)로 사이트 주소가 결정된다.
#   - 도메인 지정 시: Caddy가 Let's Encrypt로 자동 HTTPS(TLS) 발급·갱신.
#   - 로컬/개발 테스트: DOMAIN 을 비우거나 :80 으로 두면 HTTP로 동작한다.
#     예) compose의 environment 를 DOMAIN=:80 으로 바꾸거나, 아래 블록을
#         `:80 {` 로 교체하면 TLS 없이 로컬에서 확인 가능.
#
# 정적 산출물(web-dist 볼륨)은 /srv 에 마운트된다.
# index.html(메인 SPA) + companion.html(보조 창) 멀티페이지 구성.

{$DOMAIN} {
	encode gzip zstd

	# /api/* → NestJS (전역 프리픽스 /api). nest 컨테이너 내부 포트 3000.
	handle /api/* {
		reverse_proxy nest:3000
	}

	# socket.io 웹소켓 — reverse_proxy가 Upgrade/Connection 헤더를 자동 처리한다.
	handle /socket.io/* {
		reverse_proxy nest:3000
	}

	# 그 외 모든 경로 → 정적 SPA.
	# try_files 폴백은 실제 파일이 없을 때만 index.html 로 보낸다.
	# companion.html 은 실존 파일이므로 폴백 없이 그대로 서빙된다.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
