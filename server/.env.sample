# 무임하차 백엔드 환경 변수 (NestJS)
# 이 파일을 .env로 복사한 뒤 값을 채워 사용한다.
#   cp .env.sample .env
# 비밀 값(JWT_SECRET, OPENAI_API_KEY 등)은 절대 커밋하지 말 것.

# 서버
PORT=3000

# DB (RDS MySQL 프리티어)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=mooimhacha

# JWT (랜덤 32바이트 이상 권장. openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# 카카오 OAuth (카카오 개발자 콘솔에서 발급)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

# Groq (회의 중 아젠다당 1회 + 회의 후 추출 1회)
# 발급: https://console.groq.com
GROQ_API_KEY=

# 기여도 엔진 API (Python FastAPI)
CONTRIBUTION_API_URL=http://localhost:8000
